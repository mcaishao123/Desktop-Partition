<Window x:Class="桌面整理工具.FenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面分区" 
        SizeToContent="WidthAndHeight"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated"
        SizeChanged="Window_SizeChanged">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      ResizeBorderThickness="0" 
                      GlassFrameThickness="-1" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 滚动条精美样式 -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       HorizontalAlignment="Right"
                                       Width="6"
                                       Margin="0,0,2,0">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent">
                                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                                <Track.Thumb>
                                                    <Thumb Width="6" MinHeight="20">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="#66FFFFFF" CornerRadius="3"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 隐式应用滚动条样式到当前窗口内所有 ScrollViewer 上，避免 XAML 绑定冲突 -->
        <Style TargetType="ScrollViewer" BasedOn="{StaticResource ModernScrollViewer}"/>

        <!-- 文件项样式 -->
        <Style x:Key="FileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Width="70" Height="75"
                                ToolTip="{Binding FilePath}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 文件图标 -->
                                <Image Source="{Binding Icon}" 
                                       Width="32" Height="32" 
                                       Margin="0,2,0,2"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                
                                <!-- 文件名称 -->
                                <TextBlock Grid.Row="1" 
                                           Text="{Binding FileName}" 
                                           Foreground="White"
                                           FontSize="11" 
                                           TextAlignment="Center" 
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap"
                                           MaxHeight="32"
                                           Margin="0,2,0,0"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#22FFFFFF"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#44FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#33FFFFFF"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#66FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主圆角容器，使用极低透明度 #01FFFFFF 以防止鼠标与拖放事件发生物理穿透 -->
    <Border x:Name="MainBorder"
            Background="#01FFFFFF"
            BorderBrush="#4CFFFFFF"
            BorderThickness="1.5"
            CornerRadius="10"
            Padding="1">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题栏容器：支持鼠标拖拽，使用 #01FFFFFF 防止点击穿透 -->
            <Grid x:Name="TitleBar" 
                  Background="#01FFFFFF"
                  Height="32"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  MouseMove="TitleBar_MouseMove"
                  MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                


                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 分区标题（支持就地双击编辑或点击按钮编辑，标题变大加粗并显示为系统经典亮蓝色） -->
                <Grid>
                    <TextBlock x:Name="TitleText"
                               Text="快捷方式"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               MouseLeftButtonDown="TitleText_MouseLeftButtonDown"/>
                    <TextBox x:Name="TitleEditBox"
                             Foreground="White"
                             Background="#FF004488"
                             BorderBrush="#FF0096FF"
                             BorderThickness="1.5"
                             FontSize="16"
                             FontWeight="Bold"
                             VerticalAlignment="Center"
                             Margin="12,0,4,0"
                             Padding="2,0,2,0"
                             Visibility="Collapsed"
                             LostFocus="TitleEditBox_LostFocus"
                             KeyDown="TitleEditBox_KeyDown"/>
                </Grid>

                <!-- 右侧操作栏 -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center" 
                            Margin="0,0,8,0">
                    
                    <!-- 重命名按钮 -->
                    <Button x:Name="RenameButton"
                            Click="RenameButton_Click"
                            Background="Transparent" 
                            BorderThickness="0" 
                            Width="20" Height="20" 
                            ToolTip="重命名"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                                          Fill="#CCFFFFFF" 
                                          Stretch="Uniform" 
                                          Width="10" Height="10"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 删除分区按钮 -->
                    <Button x:Name="DeleteButton"
                            Click="DeleteButton_Click"
                            Background="Transparent" 
                            BorderThickness="0" 
                            Width="20" Height="20" 
                            Margin="4,0,0,0"
                            ToolTip="删除分区"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent">
                                    <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                          Fill="#CCFFFFFF" 
                                          Stretch="Uniform" 
                                          Width="10" Height="10"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 主内容区域：ListBox 绑定文件列表，支持拖放，使用 #01FFFFFF 接受拖拽 HitTest -->
            <ListBox x:Name="FileListBox"
                     Grid.Row="1"
                     Background="#01FFFFFF"
                     BorderThickness="0"
                     MinWidth="180"
                     MinHeight="90"
                     MaxWidth="330"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource FileItemStyle}"
                     AllowDrop="True"
                     DragEnter="FileListBox_DragEnter"
                     DragOver="FileListBox_DragOver"
                     Drop="FileListBox_Drop"
                     MouseDoubleClick="FileListBox_MouseDoubleClick"
                     KeyDown="FileListBox_KeyDown"
                     PreviewMouseLeftButtonDown="FileListBox_PreviewMouseLeftButtonDown"
                     PreviewMouseMove="FileListBox_PreviewMouseMove"
                     Padding="8">
                <!-- 拖拽操作指导文字（在无项目时显示） -->
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Style.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="拖拽文件到此处放入分区" 
                                                           Foreground="#55FFFFFF" 
                                                           FontSize="11"
                                                           FontStyle="Italic"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
    </Border>
</Window>
